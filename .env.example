# EarthRise Server Configuration
# Copy this file to .env and customize values.
# Environment variables override these settings.

EARTHRISE_PORT=7777
EARTHRISE_HEALTH_PORT=8080
EARTHRISE_MAX_CLIENTS=100
EARTHRISE_TICK_RATE=20
EARTHRISE_LOG_FORMAT=json
EARTHRISE_ZONE_FILE=GameData/Zones/default.zone
EARTHRISE_DB_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=Earthrise;UID=sa;PWD=Earthr1se!Dev

# Docker Compose database password (used by docker-compose.yml)
SA_PASSWORD=Earthr1se!Dev
